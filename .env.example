# Copy to .env.local for local dev, and set the same in Vercel → Settings →
# Environment Variables for production. NONE of these are NEXT_PUBLIC — they are
# server-only secrets and must never be exposed to the browser.

# --- Admin panel auth (/admin) ---
# The password the shop owner types to log in and edit quote pricing.
ADMIN_PASSWORD=change-me-to-a-strong-password
# A long random string used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# --- Supabase (stores the editable pricing) ---
# From Supabase → Project Settings → API. Use the SERVICE ROLE key (server-only).
# Run db/pricing-schema.sql once in the Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Without Supabase set, the quote calculator still works on the built-in default
# prices and the admin editor saves for the current session only.

# --- Groq (AI quote chatbot at /quote/chat) ---
# API key for the AI quote assistant. Create one at https://console.groq.com/keys
# Server-only — never exposed to the browser. Uses the llama-3.1-8b-instant model.
GROQ_API_KEY=

# --- Gemini (AI damage-photo analyzer at /quote) ---
# Server-only Google AI Studio key. Never expose this as NEXT_PUBLIC_.
GEMINI_API_KEY=

# --- Quote booking (appointments + photo drop-in) ---
# The booking flow signs a short-lived chat-session cookie. It reuses AUTH_SECRET
# above by default; set CHAT_SESSION_SECRET only if you want a separate secret.
CHAT_SESSION_SECRET=
# Appointments/leads persist in Supabase (same project as pricing above). Run
# db/booking-schema.sql once in the Supabase SQL editor. Dropped-in photos upload
# to a public "quote-photos" Storage bucket, created automatically on first use.
# Set IAM_DEV_MEMORY_STORE=1 to force the in-memory store (ignores Supabase) —
# handy for local testing before the schema is applied.
IAM_DEV_MEMORY_STORE=
# (Optional) Cloudflare Turnstile secret to require bot verification on the chat.
# Leave blank to disable. Requires adding the Turnstile widget to the client.
TURNSTILE_SECRET_KEY=
